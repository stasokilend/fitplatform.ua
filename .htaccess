Options -Indexes
RewriteEngine On

# Заголовки безопасности
<IfModule mod_headers.c>
    # Content Security Policy - разрешаем все необходимое
    Header set Content-Security-Policy "default-src 'self'; \
        script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; \
        style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; \
        img-src 'self' data: https:; \
        font-src 'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.gstatic.com data:; \
        connect-src 'self' https://api.fitplatform.ua; \
        frame-ancestors 'none'; \
        base-uri 'self'; \
        form-action 'self';"
    
    # Защита от MIME-типов
    Header set X-Content-Type-Options "nosniff"
    
    # Защита от кликджекинга
    Header set X-Frame-Options "DENY"
    
    # Защита XSS
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Cache-Control для статики
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|woff2)$">
        Header set Cache-Control "max-age=604800, public"
    </FilesMatch>
</IfModule>

# Игнорируем реальные файлы и папки
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Красивые URL
RewriteRule ^([^/]+)/?$ index.php?page=$1 [QSA,L]

# Защита
<FilesMatch "\.(sql|env|log|ini|json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

RewriteRule ^google-fit-callback\.php$ google-fit-callback.php [L]